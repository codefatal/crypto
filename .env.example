# ─── 거래소 선택 ────────────────────────────────────────────
# 'upbit' 또는 'binance' 중 하나만 활성화
ACTIVE_EXCHANGE=upbit

# ─── Upbit (ACTIVE_EXCHANGE=upbit 시 필요) ───────────────────
UPBIT_ACCESS_KEY=your_upbit_access_key
UPBIT_SECRET_KEY=your_upbit_secret_key

# ─── Binance (ACTIVE_EXCHANGE=binance 시 필요) ───────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key
BINANCE_TESTNET=false

# ─── AI (Groq — Llama 3) ────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.1
AI_MAX_RETRIES=2

# ─── Database ────────────────────────────────────────────────
# 로컬 개발: SQLite (파일 자동 생성, 별도 서버 불필요)
DATABASE_URL=sqlite:///autocrypto.db
# 운영(AWS EC2): PostgreSQL로 교체
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/autocrypto

# ─── Discord ─────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_SIGNAL_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ─── News API ────────────────────────────────────────────────
# 네이버 뉴스 (선택, 한국어 코인 뉴스 수집)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
# 글로벌 뉴스: CoinTelegraph/CoinDesk RSS (무료, 인증 불필요)
# 공포·탐욕 지수: alternative.me API (무료, 인증 불필요)

# ─── Trading Config ──────────────────────────────────────────
TRADE_ENABLED=false
MAX_OPEN_POSITIONS=5
RISK_PER_TRADE_PCT=0.02

# Upbit 전용 (KRW 기준)
MAX_POSITION_KRW=100000
MIN_VOLUME_KRW=1000000000

# Binance 전용 (USDT 기준)
MAX_POSITION_USDT=100
MIN_VOLUME_USDT=1000000

# ─── Scanner Config ──────────────────────────────────────────
SCAN_INTERVAL_SEC=60
# Upbit: "minute15" / Binance: "15m"
TIMEFRAME=minute15

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
