# ═══════════════════════════════════════════════════════════════
#  AutoCrypto .env 예시 파일
#  이 파일을 복사해서 .env로 저장 후 실제 값을 채워주세요.
#    cp .env.example .env
#
#  모든 항목에서 값 뒤에 인라인 주석(# ...)을 붙이면
#  pydantic-settings가 파싱에 실패합니다. 주석은 별도 줄에 작성하세요.
# ═══════════════════════════════════════════════════════════════

# ── 거래소 선택 ─────────────────────────────────────────────────
# upbit 또는 binance 중 하나만 선택합니다.
ACTIVE_EXCHANGE=upbit

# ── 업비트 API (ACTIVE_EXCHANGE=upbit 시 필요) ──────────────────
# https://upbit.com/mypage/open_api_management 에서 발급
UPBIT_ACCESS_KEY=your_upbit_access_key_here
UPBIT_SECRET_KEY=your_upbit_secret_key_here

# ── 바이낸스 API (ACTIVE_EXCHANGE=binance 시 필요) ──────────────
# https://www.binance.com/ko/my/settings/api-management 에서 발급
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
# 테스트넷 사용 여부 (true/false)
BINANCE_TESTNET=false

# ── Groq AI API (필수) ──────────────────────────────────────────
# https://console.groq.com 에서 무료 발급
GROQ_API_KEY=your_groq_api_key_here

# Groq 모델명 (기본값: llama-3.3-70b-versatile)
AI_MODEL=llama-3.3-70b-versatile

# AI 응답 최대 토큰 수
AI_MAX_TOKENS=2048

# 응답 온도 — 낮을수록 JSON 형식 일관성 증가 (0.0~1.0)
AI_TEMPERATURE=0.1

# JSON 파싱 실패 시 재시도 횟수
AI_MAX_RETRIES=2

# 일일 토큰 예산 상한 (Groq on_demand 티어 100,000 TPD 기준 90% 사용)
AI_DAILY_TOKEN_LIMIT=90000

# BakktaIndicator 통과 점수 최소값 — 이 값 미만은 AI 호출 안 함 (0~100)
AI_MIN_SCORE=70.0

# ── 알림 채널 ───────────────────────────────────────────────────

# Discord — 서버 채널에서 웹훅 URL 발급
# 시스템 상태/에러용 채널
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# 매매 신호 전용 채널 (비우면 DISCORD_WEBHOOK_URL 사용)
DISCORD_SIGNAL_WEBHOOK_URL=

# Telegram — @BotFather 에서 봇 생성 후 토큰 발급
# TELEGRAM_CHAT_ID: 채널이면 -100xxxxxxxxxx, 개인이면 숫자 ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── 네이버 뉴스 API (선택 사항) ─────────────────────────────────
# https://developers.naver.com/apps 에서 애플리케이션 등록 후 발급
# 미설정 시 한국어 뉴스 수집 건너뜀 (글로벌 RSS + 공포탐욕 지수는 정상 동작)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 데이터베이스 ────────────────────────────────────────────────
# 로컬 개발: sqlite:///autocrypto.db (기본값, 별도 설치 불필요)
# 운영 서버: postgresql+psycopg2://user:password@host:5432/autocrypto
DATABASE_URL=sqlite:///autocrypto.db

# ── 매매 설정 ───────────────────────────────────────────────────
# false = DryRun (실제 주문 없음, 로그/알림만), true = 실거래 활성화
TRADE_ENABLED=false

# 동시 보유 가능한 최대 포지션 수
MAX_OPEN_POSITIONS=5

# 포지션당 리스크 비율 (0.02 = 2%)
RISK_PER_TRADE_PCT=0.02

# 업비트 전용: 포지션당 최대 투자금 (KRW)
MAX_POSITION_KRW=100000

# 업비트 전용: 24h KRW 거래대금 최소 필터
MIN_VOLUME_KRW=1000000000

# 바이낸스 전용: 포지션당 최대 투자금 (USDT)
MAX_POSITION_USDT=100.0

# 바이낸스 전용: 24h USDT 거래대금 최소 필터
MIN_VOLUME_USDT=1000000.0

# ── 스캐너 설정 ─────────────────────────────────────────────────
# 뉴스 갱신 주기 (초)
SCAN_INTERVAL_SEC=60

# 캔들 타임프레임
# 업비트: minute1 / minute3 / minute5 / minute10 / minute15 / minute30 / minute60 / minute240 / day
# 바이낸스: 1m / 3m / 5m / 15m / 30m / 1h / 4h / 1d
TIMEFRAME=minute15

# 캔들 경계마다 AI 분석할 최대 심볼 수 (거래대금 상위 N개)
MAX_SYMBOLS_PER_CANDLE=30

# ── 로그 레벨 ───────────────────────────────────────────────────
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
